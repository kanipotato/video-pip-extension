{
  "manifest_version": 3,
  "name": "Video PiP Launcher",
  "version": "3.0",
  "description": "動画をPicture-in-Pictureで別ウィンドウに表示します",

  "permissions": ["activeTab", "scripting"],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
